@startuml UseCase_BloodDonationSystem
skinparam style ubuntu
skinparam backgroundColor #FEFEFE
skinparam actorBackgroundColor #D0D0D0
skinparam usecaseBackgroundColor #AAFFAA
skinparam sequenceArrowThickness 2

left to right direction

actor Donor
actor Staff
actor Admin

package "Blood Donation System" {
    usecase UC1 as "Login/Register"
    usecase UC2 as "Check Eligibility"
    usecase UC3 as "Book Appointment"
    usecase UC4 as "View Donation History"
    usecase UC5 as "Receive Donation Request"
    usecase UC6 as "Search for Donors"
    usecase UC7 as "Manage Appointments"
    usecase UC8 as "Send Donation Request"
    usecase UC9 as "Manage Blood Inventory"
    usecase UC10 as "Record Donation"
    usecase UC11 as "View Analytics Dashboard"
    usecase UC12 as "View Calendar"
    usecase UC13 as "Logout"
}

Donor --> UC1
Donor --> UC2
Donor --> UC3
Donor --> UC4
Donor --> UC5
Donor --> UC13

Staff --> UC1
Staff --> UC6
Staff --> UC7
Staff --> UC8
Staff --> UC9
Staff --> UC10
Staff --> UC13

Admin --> UC1
Admin --> UC11
Admin --> UC12
Admin --> UC13

UC1 ..> UC2 : includes
UC1 ..> UC6 : includes
UC1 ..> UC11 : includes

UC3 ..> UC7 : extends
UC10 ..> UC9 : extends
UC10 ..> UC4 : extends
@enduml
